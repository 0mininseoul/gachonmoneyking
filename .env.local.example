# Supabase Configuration
VITE_SUPABASE_URL=https://ydotomyiabchrdhytynr.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_AMPLITUDE_API_KEY=your_amplitude_api_key

# Vertex AI Gemini Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
VERTEX_AI_MODEL=gemini-2.5-flash

# Local Supabase Edge Function development only.
# Point this to the service account JSON stored outside Git.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/gachon-money-king-vertex-ai.json

# Vercel/Supabase deployed environments can use a base64-encoded service account JSON instead.
# Never print this value and never commit the decoded JSON.
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=base64_encoded_service_account_json

# Optional: lets the Supabase Edge Function forward sanitized verification stages to Vercel logs.
VERCEL_OPS_LOG_ENDPOINT=https://your-domain.vercel.app/api/ops-log

VITE_KAKAO_JS_KEY
